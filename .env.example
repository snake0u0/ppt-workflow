# 로그인 보호용 환경변수 (예시). 이 파일을 복사해 `.env` 로 만든 뒤 값을 채운다.
#   cp .env.example .env
# `.env` 는 git 에 올라가지 않는다(.gitignore). 배포 시에는 호스팅(예: Vercel)
# 프로젝트의 Environment Variables 에 동일한 키로 등록한다.

# 로그인 아이디 (기본값 1234 - 반드시 본인 값으로 바꾼다)
SITE_ID=1234

# 로그인 비밀번호 (기본값 1234 - 반드시 본인 값으로 바꾼다)
SITE_PASSWORD=1234

# 쿠키 서명용 시크릿. 로그인이 동작하려면 반드시 채워야 한다(비어 있으면 로그인 실패).
# 길고 무작위한 값으로 직접 생성한다:  openssl rand -hex 32
AUTH_SECRET=
